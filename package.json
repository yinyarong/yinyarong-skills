{
  "name": "yinyarong-skills",
  "version": "1.0.0",
  "description": "印亚荣风格公众号文章生成技能集：标题生成 + 文章撰写",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yinyarong-skills": "src/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/cli.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "claude-code",
    "skills",
    "wechat",
    "article",
    "title-generator",
    "chinese",
    "writing",
    "content-generation",
    "yinyarong"
  ],
  "author": "yinyarong",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/yinyarong-skills.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.17",
    "typescript": "^5.7.3"
  },
  "mcp": {
    "name": "yinyarong-skills",
    "version": "1.0.0",
    "skills": [
      {
        "name": "yinyarong_title",
        "description": "生成公众号爆款标题"
      },
      {
        "name": "yinyarong_article",
